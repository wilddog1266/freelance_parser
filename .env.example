# ===== DeepSeek (AI-анализ) =====
# Ключ из https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== Telegram =====
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Твой chat_id (узнать у @userinfobot) или id канала/группы
TELEGRAM_CHAT_ID=123456789

# ===== Поведение =====
# Минимальная оценка (0-100), при которой заказ отправляется в Telegram
MIN_SCORE=70
# Сколько страниц фида парсить за один запуск
PAGES_TO_PARSE=2
# Игнорировать заказы старше N часов (168 = 7 дней)
MAX_AGE_HOURS=168
# Пауза между HTTP-запросами, сек (чтобы не словить бан)
REQUEST_DELAY=1.5
# Заходить ли на страницу заказа за полным описанием (true/false)
FETCH_DETAILS=true
# Тестовый прогон: анализировать, но НЕ отправлять в Telegram (true/false)
DRY_RUN=false
# Путь к базе просмотренных заказов
DB_PATH=data/parser.db

# ===== Kwork (второй источник — раздел «Биржа») =====
# Включить парсинг Kwork. true/false (по умолчанию true).
KWORK_ENABLED=true
# Базовый адрес сайта — из него строятся ссылки на заказы. Менять не нужно.
KWORK_BASE_URL=https://kwork.ru
# Страница биржи заказов покупателей (НЕ кворки исполнителей). Менять не нужно.
KWORK_EXCHANGE_URL=https://kwork.ru/projects
# Сколько страниц биржи листать за один проход (12 заказов на страницу).
KWORK_PAGES_TO_PARSE=3
# Cookies — оставь пустым. Нужны только как fallback, если Kwork вдруг закроет
# биржу за авторизацией: тогда вставь сюда строку Cookie из браузера (DevTools →
# вкладка Network → запрос к kwork.ru → заголовок Cookie).
KWORK_COOKIES=

# ===== Локальные фильтры ДО AI =====
# DeepSeek дёшев, поэтому по умолчанию отдаём в AI почти все новые заказы,
# а локально отсекаем только мусор по стоп-словам. Антидубли, premium и старые
# заказы отсекаются всегда, независимо от этих флагов.
# Требовать ключевые слова (include_keywords). false = заказы без ключевых слов
# тоже идут в AI. (по умолчанию false)
LOCAL_INCLUDE_FILTER_ENABLED=true
# Отсекать заказы со стоп-словами (exclude_keywords) до AI. (по умолчанию true)
LOCAL_EXCLUDE_FILTER_ENABLED=true
# Отсекать заказы по бюджету (min/max) до AI. false = бюджет не режет, решает AI.
# (по умолчанию false)
LOCAL_BUDGET_FILTER_ENABLED=false
